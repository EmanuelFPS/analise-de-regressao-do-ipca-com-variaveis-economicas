# Exibindo os resultados
print(paste0("Volatilidade Anualizada: ", round(vol_anualizada2 * 100, 2), "%"))
print(paste0("VaR (95%): ", round(var_952 * 100, 2), "%"))
print(paste0("VaR (95%): ", round(var_95 * 100, 2), "%"))
# 1. Coleta de dados (últimos 2 anos de Petrobras)
precos <- tq_get("PETR4.SA", from = Sys.Date() - months(24), to = Sys.Date())
precos2 <- tq_get("^BVSP", from = Sys.Date() - months(24), to = Sys.Date())
# 2. Cálculo dos retornos diários (log-retor)
retornos <- precos %>%
tq_transmute(select = adjusted,
mutate_fun = periodReturn,
period = "daily",
type = "log",
col_rename = "retorno")
retornos2 <- precos2 %>%
tq_transmute(select = adjusted,
mutate_fun = periodReturn,
period = "daily",
type = "log",
col_rename = "retorno")
# 3. Cálculo da Volatilidade Diária e Anualizada
vol_diaria <- sd(retornos$retorno, na.rm = TRUE)
vol_anualizada <- vol_diaria * sqrt(252) # 252 dias úteis no Brasil
# 4. Cálculo do VaR (95% de confiança)
# Significa que há apenas 5% de chance de perder mais do que esse valor em um dia
var_95 <- VaR(retornos$retorno, p = 0.95, method = "historical")
# Exibindo os resultados
print(paste0("Volatilidade Anualizada: ", round(vol_anualizada * 100, 2), "%"))
print(paste0("VaR (95%): ", round(var_95 * 100, 2), "%"))
