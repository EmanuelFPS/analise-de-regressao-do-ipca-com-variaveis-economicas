## Instalação e importação de pacotes ---------------------------------------
if (!requireNamespace("pacman", quietly = TRUE)) {
install.packages("pacman")
}
pacman::p_load(car, corrplot, patchwork, skimr, tidyverse)
## Importação e transformação dos dados -------------------------------------
### IPCA --------------------------------------------------------------------
ipca <- read.csv2('tabelas/ipca_mensal_1980a2025_com_categorias.csv',
header = TRUE,
skip = 2,
nrows = 553)
ipca <- ipca[-1,c(1,3)]
colnames(ipca) <- c("mes", 'ipca')
ipca <- ipca[-c(1:240), ]
ipca$ipca <- as.numeric(gsub(',', '.', ipca$ipca))
ipca$mes <- as.Date(
paste("01", ipca$mes),
format = "%d %B %Y"
)
### DLGG --------------------------------------------------------------------
dlgg <- read.csv2('tabelas/bcdata.sgs.4536.csv',
header = TRUE)
dlgg <- dlgg[,2]
### DOLAR -------------------------------------------------------------------
dolar <- scan('tabelas/dolar.txt', sep = ',')
### EXPECTATIVA DO IPCA -----------------------------------------------------
expectativa_ipca <- read.csv2('tabelas/expectativa_ipca.csv',
header = TRUE)
expectativa_ipca <- expectativa_ipca[,2]
### PIB ---------------------------------------------------------------------
pib <- read.csv2('tabelas/STP-20260206161420809.csv',
header = TRUE)
pib <- pib[,2]
pib <- as.numeric(sub(",", ".", gsub("\\.", "", pib)))
### SELIC -------------------------------------------------------------------
selic <- scan('tabelas/selic.txt', sep = ',')
### ELEICAO -----------------------------------------------------------------
eleicao <- as.factor(scan('tabelas/eleicao.txt', sep = ','))
### PANDEMIA ----------------------------------------------------------------
pandemia <- as.factor(scan('tabelas/pandemia.txt', sep = ','))
## União dos dados ----------------------------------------------------------
ipca <- ipca[-c(1:24),]
dolar <- dolar[-c(1:24)]
pib <- pib[-c(1:24)]
selic <- selic[-c(1:24)]
eleicao <- eleicao[-c(1:24)]
pandemia <- pandemia[-c(1:24)]
dados <- tibble(ipca, dlgg, dolar, expectativa_ipca,
pib, selic, eleicao, pandemia)
head(dados)
tail(dados)
skim(dados)
cor_mat <- dados %>%
select(-mes, -eleicao, -pandemia) %>%
cor()
corrplot(
cor_mat,
method = "color",
type = "upper",
addCoef.col = "black",
tl.col = "black",
tl.srt = 45
)
## Gráficos -----------------------------------------------------------------
gline_mes_ipca <- ggplot(
dados, aes(x = mes, y = ipca)) +
geom_line() +
theme_minimal()
gline_mes_dlgg <- ggplot(
dados, aes(x = mes, y = dlgg)) +
geom_line() +
theme_minimal()
gline_mes_expectativa <- ggplot(
dados, aes(x = mes, y = expectativa_ipca)) +
geom_line() +
theme_minimal()
gline_mes_dolar <- ggplot(
dados, aes(x = mes, y = dolar)) +
geom_line() +
theme_minimal()
gline_mes_pib <- ggplot(
dados, aes(x = mes, y = pib)) +
geom_line() +
theme_minimal()
gline_mes_selic <- ggplot(
dados, aes(x = mes, y = selic)) +
geom_line() +
theme_minimal()
(gline_mes_ipca | gline_mes_expectativa) /
(gline_mes_dlgg | gline_mes_dolar) /
(gline_mes_pib | gline_mes_selic)
## Boxplots -----------------------------------------------------------------
gboxplot_pandemia_ipca <- ggplot(
dados, aes(x = pandemia, y = ipca, fill = pandemia)) +
geom_boxplot() +
theme_minimal()
gboxplot_eleicao_ipca <- ggplot(
dados, aes(x = eleicao, y = ipca, fill = eleicao)) +
geom_boxplot() +
theme_minimal()
gboxplot_pandemia_dlgg <- ggplot(
dados, aes(x = pandemia, y = dlgg, fill = pandemia)) +
geom_boxplot() +
theme_minimal()
gboxplot_eleicao_dlgg <- ggplot(
dados, aes(x = eleicao, y = dlgg, fill = eleicao)) +
geom_boxplot() +
theme_minimal()
gboxplot_pandemia_dolar <- ggplot(
dados, aes(x = pandemia, y = dolar, fill = pandemia)) +
geom_boxplot() +
theme_minimal()
gboxplot_eleicao_dolar <- ggplot(
dados, aes(x = eleicao, y = dolar, fill = eleicao)) +
geom_boxplot() +
theme_minimal()
gboxplot_pandemia_expectativa <- ggplot(
dados, aes(x = pandemia, y = expectativa_ipca, fill = pandemia)) +
geom_boxplot() +
theme_minimal()
gboxplot_eleicao_expectativa <- ggplot(
dados, aes(x = eleicao, y = expectativa_ipca, fill = eleicao)) +
geom_boxplot() +
theme_minimal()
gboxplot_pandemia_pib <- ggplot(
dados, aes(x = pandemia, y = pib, fill = pandemia)) +
geom_boxplot() +
theme_minimal()
gboxplot_eleicao_pib <- ggplot(
dados, aes(x = eleicao, y = pib, fill = eleicao)) +
geom_boxplot() +
theme_minimal()
gboxplot_pandemia_selic <- ggplot(
dados, aes(x = pandemia, y = selic, fill = pandemia)) +
geom_boxplot() +
theme_minimal()
gboxplot_eleicao_selic <- ggplot(
dados, aes(x = eleicao, y = selic, fill = eleicao)) +
geom_boxplot() +
theme_minimal()
(gboxplot_pandemia_ipca | gboxplot_pandemia_expectativa) /
(gboxplot_pandemia_dolar | gboxplot_pandemia_dlgg) /
(gboxplot_pandemia_pib | gboxplot_pandemia_selic)
(gboxplot_eleicao_ipca | gboxplot_eleicao_expectativa) /
(gboxplot_eleicao_dolar | gboxplot_eleicao_dlgg) /
(gboxplot_eleicao_pib | gboxplot_eleicao_selic)
mod_completo <- lm(ipca ~ ., dados[, -1])
summary(mod_completo)
vif(mod_completo)
dados_modelo <- dados %>%
select(-dolar)
mod <- lm(ipca ~ ., dados_modelo[, -1])
step(mod)
dados_modelo <- dados_modelo %>%
select(-pandemia, -eleicao)
mod <- lm(ipca ~ ., dados_modelo[, -1])
summary(mod)
residuos <- residuals(mod)
shapiro.test(residuos)$p.value
par(mfrow = c(1, 3))
qqnorm(residuos, xlab = 'Quantis Teóricos',
ylab = 'Quantis Empíricos')
qqline(residuos)
plot(fitted(mod), residuos, ylab = 'Resíduos',
xlab = 'Valores Ajustados')
abline(h = 0, col = 'Red', lty = 2)
plot(residuos, ylab = 'Resíduos',
xlab = 'Ordem')
abline(h = 0, col = 'Red', lty = 2)
cooksd <- cooks.distance(mod)
sample_size <- nrow(dados_modelo)
maximo <- max(cooksd, 1.1)
plot(cooksd, pch = '*', ylab = 'Distância de Cook',
ylim = c(0, maximo))
abline(h = 1, col = 'orange')
abline(h = 4/sample_size, col = 'red')
par(mfrow = c(1, 3))
qqnorm(residuos, xlab = 'Quantis Teóricos',
ylab = 'Quantis Empíricos')
qqline(residuos)
plot(fitted(mod), residuos, ylab = 'Resíduos',
xlab = 'Valores Ajustados')
abline(h = 0, col = 'Red', lty = 2)
plot(residuos, ylab = 'Resíduos',
xlab = 'Ordem')
abline(h = 0, col = 'Red', lty = 2)
skim(dados) |>
print(width = Inf)
